# Copy this file to ".env" and fill in your own values.

# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Your bot's Application ID (a.k.a. Client ID), from the same page's
# "General Information" tab. Needed to register the /post-sleep-message
# slash command.
CLIENT_ID=123456789012345678

# The server (guild) this bot operates in
GUILD_ID=123456789012345678

# The channel where the bot should post its reaction-role message.
# The bot posts the message itself on startup (and reuses the same one
# on future restarts), so you don't need a message ID here.
REACTION_ROLE_CHANNEL_ID=123456789012345678

# Optional: customize the text of the message the bot posts.
# If left unset, a sensible default is used.
REACTION_ROLE_MESSAGE_TEXT=React ✅ to mark yourself asleep, ❌ to mark yourself awake.

# Role IDs
ASLEEP_ROLE_ID=123456789012345678
AWAKE_ROLE_ID=123456789012345678

# Channel where "X was asleep for Y" logs get posted
LOG_CHANNEL_ID=123456789012345678

# Emojis used on the reaction-role message
# Unicode emojis work as-is. For custom server emojis use the format name:id
TICK_EMOJI=✅
X_EMOJI=❌

# Optional: if set, reacting with TICK_EMOJI will move the user into this
# voice channel — but only if they're already connected to a voice
# channel. If unset, this feature is skipped entirely.
ASLEEP_VOICE_CHANNEL_ID=123456789012345678

# Optional: same idea, but for X_EMOJI (waking up). If set, reacting ❌
# moves the user into this voice channel, only if they're already
# connected to a voice channel. If unset, this feature is skipped.
AWAKE_VOICE_CHANNEL_ID=123456789012345678
